{
  "mcpServers": {
    "learning": {
      "command": "node",
      "args": [
        "/opt/homebrew/lib/node_modules/learning-service/scripts/cli.js",
        "--mcp"
      ]
    }
  },
  "permissions": {
    "allow": [
      "Bash(curl *)",
      "Bash(npx tsc *)",
      "Bash(npm run build)",
      "Bash(npm run dev)",
      "Bash(npm run typecheck)",
      "Bash(npm run lint)"
    ]
  }
}
